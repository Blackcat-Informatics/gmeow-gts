SmalltalkCISpec {
  #loading : [
    SCIMetacelloLoadSpec {
      #baseline : 'Gts',
      #directory : 'smalltalk/src',
      #load : [ 'tests' ],
      #onWarningLog : true,
      #platforms : [ #pharo ]
    }
  ],
  #testing : {
    #include : {
      #packages : [ 'Gts-Tests' ]
    }
  }
}
