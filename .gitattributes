# The conformance corpus is byte-exact binary data — never normalize line
# endings or treat as text.
vectors/*.gts -text -diff
vectors/tar/*.tar -text -diff
vectors/tar/*.tar.gz -text -diff
vectors/tar/*.tar.zst -text -diff

# Lockfiles are generated; collapse in diffs/reviews.
ts/package-lock.json linguist-generated=true -diff
rust/Cargo.lock linguist-generated=true -diff
go/go.sum linguist-generated=true -diff
ietf/draft-audley-gts-graph-transport-substrate-00.xml linguist-generated=true

# YAML and copied upstream license text require space indentation.
.pre-commit-config.yaml whitespace=trailing-space,space-before-tab
go/.golangci.yml whitespace=trailing-space,space-before-tab
.github/workflows/*.yml whitespace=trailing-space,space-before-tab
.github/workflows/*.yaml whitespace=trailing-space,space-before-tab
quality/*.json whitespace=trailing-space,space-before-tab
ietf/draft-audley-gts-graph-transport-substrate-00.xml whitespace=trailing-space,space-before-tab
scripts/*.py whitespace=trailing-space,space-before-tab
python/**/*.py whitespace=trailing-space,space-before-tab
