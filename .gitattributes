# The conformance corpus is byte-exact binary data — never normalize line
# endings or treat as text.
vectors/*.gts -text -diff
vectors/tar/*.tar -text -diff
vectors/tar/*.tar.gz -text -diff
vectors/tar/*.tar.zst -text -diff

# Lockfiles are generated; collapse in diffs/reviews.
ts/package-lock.json linguist-generated=true -diff
rust/Cargo.lock linguist-generated=true -diff
go/go.sum linguist-generated=true -diff

# YAML and copied upstream license text require space indentation.
.github/workflows/julia-tagbot.yml whitespace=trailing-space,space-before-tab
julia/LICENSE-APACHE whitespace=trailing-space,space-before-tab
